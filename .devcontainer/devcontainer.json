{
    "name": "DR3DR3-DOTAI",

    "build": {
        "dockerfile": "Dockerfile"
    },

    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
    "workspaceFolder": "/workspace",

    // Extra bind mounts from the host. Cross-platform (Windows + macOS/Linux):
    // exactly one of USERPROFILE (Windows) / HOME (macOS/Linux) is set, so the
    // concatenation below resolves to the correct home dir on each host.
    "mounts": [
        // Host share — work on host files from inside the container (read-write).
        // Create it on the host first:  Windows  ->  mkdir %USERPROFILE%\host-share
        //                               macOS    ->  mkdir -p ~/host-share
        // (Docker Desktop will auto-create it as root if missing, which can cause
        //  permission issues, so creating it yourself first is recommended.)
        "source=${localEnv:USERPROFILE}${localEnv:HOME}/host-share,target=/host,type=bind,consistency=cached"
    ],

    "customizations": {
        "vscode": {
            "extensions": [
                "github.vscode-pull-request-github",
                "github.copilot",
                "github.copilot-chat",
                "amazonwebservices.aws-toolkit-vscode",
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint",
                "ms-azuretools.vscode-docker",
                "ms-vscode.live-server"
            ],
            "settings": {
                "editor.fontFamily": "FiraCode Nerd Font, monospace",
                "editor.fontSize": 14,
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    }
                }
            }
        }
    },

    // Set environment variables
    "remoteEnv": {
        "AWS_REGION": "ap-southeast-2",
        // Point SSH (and op's SSH-based unlock) at the mounted 1Password agent.
        "SSH_AUTH_SOCK": "/home/dev/.1password/agent.sock",
        // Reach the host's native Ollama (OrbStack maps host.docker.internal).
        "OLLAMA_HOST": "http://host.docker.internal:11434"
    },
    
    // Connect as the non-root user.
    // Hardcoded to match ARG USERNAME=dev in the Dockerfile.
    // If you change the USERNAME build arg, update this value to match.
    "remoteUser": "dev",

    // Configure git identity at container start (runs as the remoteUser).
    // This ensures the correct identity is used for commits made inside the container.
    "postCreateCommand": "git config --global user.name 'André Dreyer' && git config --global user.email 'github@andredreyer.com'"
    
}

