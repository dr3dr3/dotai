{
    "name": "DR3DR3-DOTAI",

    "build": {
        "dockerfile": "Dockerfile"
    },

    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
    "workspaceFolder": "/workspace",

    // Extra bind mounts from the macOS host.
    "mounts": [
        // 1Password biometric SSH / CLI agent. The host app must have
        // Settings ▸ Developer ▸ "Use the SSH agent" enabled. The socket only
        // exists while 1Password is running — if it's absent at boot, Docker
        // creates a *directory* in its place, so keep 1Password running.
        // In-container `op`/`varlock` then resolve op:// refs with a biometric tap.
        "source=${localEnv:HOME}/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock,target=/home/dev/.1password/agent.sock,type=bind",
        // Host share — work on host files from inside the container (read-write).
        // Create it on the host first:  mkdir -p ~/host-share
        "source=${localEnv:HOME}/host-share,target=/host,type=bind,consistency=cached"
    ],

    "customizations": {
        "vscode": {
            "extensions": [
                "github.vscode-pull-request-github",
                "github.copilot",
                "github.copilot-chat",
                "amazonwebservices.aws-toolkit-vscode",
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint",
                "ms-azuretools.vscode-docker",
                "ms-vscode.live-server"
            ],
            "settings": {
                "editor.fontFamily": "FiraCode Nerd Font, monospace",
                "editor.fontSize": 14,
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    }
                }
            }
        }
    },

    // Set environment variables
    "remoteEnv": {
        "AWS_REGION": "ap-southeast-2",
        // Point SSH (and op's SSH-based unlock) at the mounted 1Password agent.
        "SSH_AUTH_SOCK": "/home/dev/.1password/agent.sock",
        // Reach the host's native Ollama (OrbStack maps host.docker.internal).
        "OLLAMA_HOST": "http://host.docker.internal:11434"
    },
    
    // Connect as the non-root user.
    // Hardcoded to match ARG USERNAME=dev in the Dockerfile.
    // If you change the USERNAME build arg, update this value to match.
    "remoteUser": "dev",

    // Configure git identity at container start (runs as the remoteUser).
    // This ensures the correct identity is used for commits made inside the container.
    "postCreateCommand": "git config --global user.name 'André Dreyer' && git config --global user.email 'github@andredreyer.com'"
    
}

