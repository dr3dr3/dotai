# Profile: Pi Harness (@earendil-works/pi-coding-agent)
# See profiles/README.md for the contract. Committed config only — no secrets.

HARNESS_PROFILE_NAME="pi"

# Pi is installed in the image.
HARNESS_CMD="pi"

# Substrate wiring proof only; a real deployment sets the workflow.
HARNESS_ARGS="--version"

# Pi reads its model config from ~/.pi/agent/models.json (NOT ~/.config/pi).
# config/pi/models.json defines an OpenAI-compatible "ollama" provider pointed at
# host.docker.internal:11434/v1 — the host Mac's native Ollama. Committed, non-secret
# (Ollama ignores the dummy apiKey). In the hardened sandbox the agent has NO route to
# the host (internal_net + egress allowlist), so this provider only resolves in the open
# devcontainer; in the sandbox it fails closed unless host.docker.internal is allowlisted.
HARNESS_CONFIG_SRC="profiles/config/pi"
HARNESS_CONFIG_DST="${HOME:-/home/dev}/.pi/agent"

# IMPORTANT: Pi has NO built-in permission system. The container + egress proxy are
# the outer sandbox; we ALSO require the inner filesystem-confinement belt
# (Anthropic sandbox-runtime) so Pi can't read/write outside the working tree.
# sandbox-runtime is installed in the image; this confines fs to the cwd.
SANDBOX_RUN_WRAPPER="npx --yes @anthropic-ai/sandbox-runtime --"
