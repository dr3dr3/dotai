# Profile: Claude Code (Anthropic)
# The substrate sources this in the agent phase (phases/20-agent.sh) and execs the
# harness. Committed config only — NEVER put secrets here (they come via the two-phase
# secret flow). See profiles/README.md for the full contract.

HARNESS_PROFILE_NAME="claude-code"

# The binary the substrate execs. Claude Code is installed in the image.
HARNESS_CMD="claude"

# Args. The WORKFLOW (what prompt/loop) is out of scope for the substrate — a real
# deployment overrides this. Default to printing version then exiting, so the
# substrate is provably wired without running an agent loop.
HARNESS_ARGS="--version"

# Config staged into $HOME/.claude before exec. Reuses the repo deny-list verbatim
# (Read(.env*), *.pem, *.key, sudo denied) — see profiles/config/claude-code/.
HARNESS_CONFIG_SRC="profiles/config/claude-code"
HARNESS_CONFIG_DST="${HOME:-/home/dev}/.claude"

# Claude Code has its own permission system, so the container+proxy are sufficient.
# The inner sandbox-runtime belt is optional here; leave the wrapper empty.
# SANDBOX_RUN_WRAPPER=""
