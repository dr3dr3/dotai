# Profile: Codex (OpenAI)
# See profiles/README.md for the contract. Committed config only — no secrets.

HARNESS_PROFILE_NAME="codex"

# Codex CLI is installed in the image (@openai/codex).
HARNESS_CMD="codex"

# Substrate wiring proof only; a real deployment sets the workflow.
HARNESS_ARGS="--version"

HARNESS_CONFIG_SRC="profiles/config/codex"
HARNESS_CONFIG_DST="${HOME:-/home/dev}/.codex"

# Codex has its own sandboxing/approvals; container+proxy suffice. Wrapper optional.
# SANDBOX_RUN_WRAPPER=""
