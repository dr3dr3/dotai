# Profile: selftest (testing only — not a real harness)
# Execs the agent-phase assertion script instead of an AI harness, so an end-to-end
# run proves the two-phase boundary from the inside without needing harness auth.
# Select it with SANDBOX_PROFILE=selftest. See test/README.md.

HARNESS_PROFILE_NAME="selftest"
HARNESS_CMD="$SANDBOX_DIR/test/assert-agent-phase.sh"
HARNESS_ARGS=""
# No config to stage; no inner wrapper needed for the assertion script.
