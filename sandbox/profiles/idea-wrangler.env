# Profile: idea-wrangler (the first concrete workload that runs IN the sandbox)
# Boots the Idea Wrangler agent. The agent definition + standing context + seed are
# mounted into the container (see agents/idea-wrangler/compose.yml); this profile just
# points the substrate at the workload's run.sh. Committed config only — no secrets.

HARNESS_PROFILE_NAME="idea-wrangler"

# The workload's runner (mounted at /opt/workload). It loads context + seed, runs
# Claude one-shot read-only, then emits the concept to Linear via email.
HARNESS_CMD="/opt/workload/run.sh"
HARNESS_ARGS=""

# Reuse the Claude Code deny-list (denies reading .env/*.pem/*.key//run/sandbox + sudo).
# Combined with --permission-mode bypassPermissions in the agent, this lets the model
# run read/grep/curl/python for research while it still cannot read secrets.
HARNESS_CONFIG_SRC="profiles/config/claude-code"
HARNESS_CONFIG_DST="${HOME:-/home/dev}/.claude"

# No inner wrapper: Claude Code has its own permission model, and the container + egress
# allowlist are the sandbox. The model also has NO send capability (emit is a post-step).
# SANDBOX_RUN_WRAPPER=""
